# Set variables
set $workspace1 "dev"
set $workspace2 "web"
set $workspace3 "chat"
set $workspace4 "mail"
set $workspace5 "audio"
set $workspace6 "video"
set $workspace7 "vis"
set $workspace8 "doc"
set $workspace9 "term"
set $workspace0 "other"

set $polybar_theme docky

# Font family and size
font pango:JetBrainsMono NFP 10

# Set the modifier key (Win key)
set $mod Mod4

# Use Mouse+$mod to drag floating windows to their wanted position
floating_modifier $mod

# Disable focus following mouse
focus_follows_mouse no

# Start a terminal
bindsym $mod+Return exec alacritty

# Kill focused window
bindsym $mod+Shift+q kill

# Start rofi (a program launcher)
bindsym $mod+d exec --no-startup-id "$HOME/.config/polybar/$polybar_theme/scripts/launcher.sh"

# Switch style
bindsym $mod+Shift+s exec --no-startup-id "$HOME/.config/polybar/$polybar_theme/scripts/style-switch.sh"

# Switch style
bindsym $mod+Shift+c exec --no-startup-id "$HOME/.config/polybar/$polybar_theme/scripts/color-switch.sh"

# Print screen
bindsym Print exec --no-startup-id xfce4-screenshooter

# Power menu
bindsym $mod+Shift+p exec --no-startup-id "$HOME/.config/polybar/$polybar_theme/scripts/powermenu.sh"

# Control screen brightness
bindsym XF86MonBrightnessUp exec --no-startup-id light -A 5
bindsym XF86MonBrightnessDown exec --no-startup-id light -U 5

## Control volume
bindsym XF86AudioRaiseVolume exec --no-startup-id i3-volume up 10
bindsym XF86AudioLowerVolume exec --no-startup-id i3-volume down 10
bindsym XF86AudioMute exec --no-startup-id i3-volume mute

# Change focus
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

# Move focused window
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

# Split in horizontal orientation
bindsym $mod+o split h

# Split in vertical orientation
bindsym $mod+v split v

# Enter fullscreen mode for the focused container
bindsym $mod+f fullscreen

# Change container layout (stacked, tabbed, toggle split)
bindsym $mod+s layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split

# Toggle tiling / floating
bindsym $mod+Shift+space floating toggle

